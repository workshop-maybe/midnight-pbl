# Andamio API key — required, never exposed to client
ANDAMIO_API_KEY=

# Andamio gateway base URL — required
# Preprod: https://preprod.api.andamio.io
# Mainnet: https://api.andamio.io
ANDAMIO_GATEWAY_URL=https://preprod.api.andamio.io

# Cardano network (preprod | mainnet | preview)
CARDANO_NETWORK=preprod

# Course ID for this single-course deployment
COURSE_ID=
