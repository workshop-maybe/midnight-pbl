---
/**
 * Base HTML layout.
 *
 * Provides the <html> shell with charset, viewport, Google Fonts,
 * and global CSS. All other layouts compose on top of this.
 *
 * All SEO-relevant meta tags are owned by `<SEOHead />`. Do not add
 * meta tags here directly — if a new SEO surface is needed, extend
 * `SEOHead.astro` and the `SEOProps` type below.
 */
import SEOHead from "@/components/seo/SEOHead.astro";

export interface SEOProps {
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  jsonLd?: unknown[];
}

interface Props extends SEOProps {
  title: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  jsonLd,
} = Astro.props;

import "@/styles/globals.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Process shim: Mesh SDK transitive deps reference `process` which
         doesn't exist in the browser. The full vite-plugin-node-polyfills
         process shim can't be used because it shadows Node's real process.env
         in the server build. This inline script runs before any module scripts
         (which are deferred), providing the global before islands hydrate. -->
    <script is:inline>
      if (typeof globalThis.process === "undefined") {
        globalThis.process = {
          env: {},
          version: "",
          browser: true,
          nextTick: function(cb) { var args = Array.prototype.slice.call(arguments, 1); queueMicrotask(function() { cb.apply(null, args); }); }
        };
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Urbanist:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-midnight text-mn-text font-body antialiased flex min-h-screen flex-col">
    <slot />
  </body>
</html>
