---
/**
 * App layout with navigation and footer.
 *
 * Wraps content in BaseLayout + Nav + Footer. Forwards all SEO props
 * through to BaseLayout.
 */
import BaseLayout, { type SEOProps } from "@/layouts/BaseLayout.astro";
import Nav from "@/components/layout/Nav.astro";
import Footer from "@/components/layout/Footer.astro";

interface Props extends SEOProps {
  title: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  jsonLd,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType={ogType}
  noindex={noindex}
  jsonLd={jsonLd}
>
  <Nav />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
