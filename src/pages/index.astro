---
/**
 * Course Overview / Homepage
 *
 * Prerendered at build time — zero API calls at request time.
 * Rebuild when course content changes.
 */
export const prerender = true;

import AppLayout from "@/layouts/AppLayout.astro";
import ModuleCard from "@/components/course/ModuleCard.astro";
import { fetchCourseModules } from "@/lib/gateway.server";
import { COURSE_ID } from "astro:env/server";
import { BRANDING } from "@/config/branding";

if (!COURSE_ID) {
  return Astro.redirect("/");
}

const modules = await fetchCourseModules(COURSE_ID);

const sorted = [...modules].sort((a, b) => {
  const codeA = parseInt(a.moduleCode ?? "0", 10);
  const codeB = parseInt(b.moduleCode ?? "0", 10);
  return codeA - codeB;
});
---

<AppLayout title={BRANDING.fullTitle}>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-20">
    <!-- Midnight mark + wordmark -->
    <div class="mb-12 sm:mb-16 flex items-start gap-5">
      <img
        src="/midnight_logo_pack/02_Symbol/Midnight-RGB_Symbol-White.svg"
        alt=""
        class="mt-1 h-12 w-12 opacity-40 sm:h-14 sm:w-14"
      />
      <div>
        <p class="font-heading text-4xl font-bold tracking-tight text-mn-text sm:text-5xl md:text-6xl">
          midnight pbl
        </p>
        <p class="mt-1 font-heading text-lg text-mn-text-muted sm:text-xl">
          From Aiken to Compact
        </p>
      </div>
    </div>

    <!-- Course description -->
    <div class="mb-12 sm:mb-16 max-w-2xl">
      <p class="text-base text-mn-text-muted leading-relaxed sm:text-lg">
        {BRANDING.longDescription}
      </p>
    </div>

    <!-- Module list -->
    <div class="mb-12 sm:mb-16">
      <h2 class="mb-6 text-sm font-medium uppercase tracking-wider text-mn-text-muted">
        Modules
      </h2>
      {sorted.length === 0 ? (
        <p class="text-mn-text-muted py-4">
          No modules available yet.
        </p>
      ) : (
        <div class="divide-y divide-midnight-border border-t border-b border-midnight-border">
          {sorted.map((module, index) => (
            <ModuleCard module={module} index={index} />
          ))}
        </div>
      )}
    </div>

    <!-- Credentials note -->
    <div class="mb-12 sm:mb-16">
      <p class="text-sm text-mn-text-muted">
        Self-paced. On-chain credentials via{" "}
        <a
          href={BRANDING.links.andamio}
          target="_blank"
          rel="noopener noreferrer"
          class="text-mn-primary transition-colors hover:text-mn-text underline underline-offset-2"
        >
          Andamio
        </a>.
      </p>
    </div>

    <!-- Three ways to take this course -->
    <div class="mb-12 sm:mb-16">
      <h2 class="mb-4 font-heading text-lg font-medium text-mn-text sm:text-xl">
        Three ways to learn
      </h2>
      <p class="mb-10 text-sm text-mn-text-muted leading-relaxed max-w-2xl">
        This course runs on a new delivery model: one source of content, three interfaces. The same lessons, assignments, and credentials — whether you read them in a browser, learn them with an AI instructor, or fork them to teach your own version.
      </p>

      <div class="space-y-8">
        <!-- Web -->
        <div>
          <h3 class="font-heading text-base font-medium text-mn-text">
            On the web
          </h3>
          <p class="mt-2 text-sm text-mn-text-muted leading-relaxed max-w-2xl">
            Browse lessons in your browser. Submit assignments on-chain via wallet connection. No setup required.
          </p>
          <a
            href={sorted.length > 0 ? `/learn/${sorted[0].moduleCode}/1` : "#"}
            class="mt-3 inline-flex items-center gap-1.5 text-sm text-mn-primary transition-colors hover:text-mn-text underline underline-offset-2"
          >
            Start learning &rarr;
          </a>
        </div>

        <!-- Agent harness -->
        <div>
          <h3 class="font-heading text-base font-medium text-mn-text">
            In Claude Code
          </h3>
          <p class="mt-2 text-sm text-mn-text-muted leading-relaxed max-w-2xl">
            Clone the repo, run <code class="text-mn-primary">/learn</code>. An AI instructor delivers lessons conversationally, guides exercises, and adapts to your pace. Progress tracked locally — no account needed.
          </p>
          <a
            href="https://github.com/workshop-maybe/midnight-pbl"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1.5 text-sm text-mn-primary transition-colors hover:text-mn-text underline underline-offset-2"
          >
            Clone and /learn &rarr;
          </a>
        </div>

        <!-- Fork as template -->
        <div>
          <h3 class="font-heading text-base font-medium text-mn-text">
            Fork and teach
          </h3>
          <p class="mt-2 text-sm text-mn-text-muted leading-relaxed max-w-2xl">
            Fork the repo, swap in your own content, issue credentials on the same protocol. The repo is the course — you own the compiler.
          </p>
          <a
            href="https://github.com/workshop-maybe/midnight-pbl/fork"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex items-center gap-1.5 text-sm text-mn-primary transition-colors hover:text-mn-text underline underline-offset-2"
          >
            Fork this repo &rarr;
          </a>
        </div>
      </div>

      <p class="mt-8 text-sm text-mn-text-muted">
        One source of truth. Three interfaces. Same SLTs, same assignments, same credentials.
      </p>
    </div>

    <!-- Community -->
    <div class="border-t border-midnight-border pt-10 sm:pt-12">
      <p class="mb-4 text-base text-mn-text-muted leading-relaxed">
        This course is a free community resource. It's made to be refined
        over time by the people who use it — if something is unclear, missing,
        or could be better, that's a contribution waiting to happen.
      </p>
      <a
        href="https://github.com/workshop-maybe/midnight-pbl/issues"
        target="_blank"
        rel="noopener noreferrer"
      >
        <button
          class="inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mn-primary border border-midnight-border bg-transparent text-mn-text hover:bg-midnight-surface px-5 py-2.5 text-sm rounded-sm min-h-[44px]"
        >
          Give Feedback
        </button>
      </a>
    </div>

    <!-- Midnight mark -->
    <div class="mt-16 flex justify-center sm:mt-20">
      <a href="https://midnight.network" target="_blank" rel="noopener noreferrer">
        <img
          src="/midnight_logo_pack/01_symbol_wordmark/Horizontal/Midnight-RGB_Logo-Horizontal-White.svg"
          alt="Midnight"
          class="h-6 opacity-20 transition-opacity hover:opacity-40"
        />
      </a>
    </div>
  </div>
</AppLayout>
