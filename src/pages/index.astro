---
/**
 * Course Overview / Homepage
 *
 * Prerendered at build time — zero API calls at request time.
 * Rebuild when course content changes.
 */
export const prerender = true;

import AppLayout from "@/layouts/AppLayout.astro";
import ModuleCard from "@/components/course/ModuleCard.astro";
import { fetchCourseModules } from "@/lib/gateway.server";
import { CURRENT_NETWORK } from "@/config/network";
import { BRANDING } from "@/config/branding";
import { buildCourseSchema, buildFAQPage, type FAQEntry } from "@/lib/seo/schema";

const courseId = CURRENT_NETWORK.courseId;

if (!courseId) {
  return Astro.redirect("/");
}

const modules = await fetchCourseModules(courseId);

const sorted = [...modules].sort((a, b) => {
  const codeA = parseInt(a.moduleCode ?? "0", 10);
  const codeB = parseInt(b.moduleCode ?? "0", 10);
  return codeA - codeB;
});

// Homepage SEO description: includes the niche keyword targets naturally.
const homepageDescription =
  "Midnight for Cardano developers. Learn to take Aiken smart contracts to Compact on Midnight Network, earn on-chain Midnight credentials, and practice proof-of-learned via project-based assignments.";

// FAQ: single source of truth. Rendered once as visible HTML, once as
// FAQPage JSON-LD. Keep the strings identical on both sides — Google
// penalizes FAQ rich results when schema text drifts from the DOM.
const FAQ_ENTRIES: FAQEntry[] = [
  {
    question: "Do I need ADA to take this course?",
    answer:
      "No. You sign in with a Cardano wallet, but the course itself is free and transactions are sponsored where needed, so you do not need ADA to earn credentials.",
  },
  {
    question: "What is the difference between Aiken and Compact?",
    answer:
      "Aiken is a smart contract language for the Cardano main chain. Compact is the smart contract language for Midnight Network, which extends Cardano with privacy-preserving programmability. The course moves you from Aiken fundamentals into Compact so you can build on Midnight with context you already have.",
  },
  {
    question: "Are my credentials verifiable outside Andamio?",
    answer:
      "Yes. Credentials are issued on-chain via the Andamio protocol, so anyone with the credential reference can verify authenticity independently of the Andamio app.",
  },
  {
    question: "Can I fork this course?",
    answer:
      "Yes. The repo is the course. Fork it, edit src/config/branding.ts and the content/ directory, and ship your own version on the same Andamio tooling. The SEO plumbing is fork-safe — change BRANDING.siteUrl and every canonical, OG, sitemap, and robots.txt entry updates.",
  },
  {
    question: "How long does the course take?",
    answer:
      "Self-paced across six modules. Most learners complete it in roughly 15 to 25 hours of focused work, depending on prior Cardano and smart-contract experience.",
  },
];

const courseJsonLd = buildCourseSchema({
  courseName: BRANDING.fullTitle,
  courseDescription: homepageDescription,
  siteUrl: BRANDING.siteUrl,
  modules: sorted,
  credentialAwarded:
    "On-chain Midnight credential issued via the Andamio protocol",
});

const faqJsonLd = buildFAQPage(FAQ_ENTRIES);
---

<AppLayout
  title={BRANDING.fullTitle}
  description={homepageDescription}
  canonical="/"
  jsonLd={[courseJsonLd, faqJsonLd]}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-20">
    <!-- Hero symbol + wordmark -->
    <div class="mb-12 sm:mb-16 flex items-start gap-5">
      {BRANDING.logo.heroSymbol && (
        <img
          src={BRANDING.logo.heroSymbol}
          alt=""
          class="mt-1 h-12 w-12 opacity-40 sm:h-14 sm:w-14"
        />
      )}
      <div>
        <p class="font-heading text-4xl font-bold tracking-tight text-mn-text sm:text-5xl md:text-6xl">
          {BRANDING.hero.title}
        </p>
        <p class="mt-1 font-heading text-lg text-mn-text-muted sm:text-xl">
          {BRANDING.hero.subtitle}
        </p>
      </div>
    </div>

    <!-- Course description -->
    <div class="mb-12 sm:mb-16 max-w-2xl">
      <p class="text-base text-mn-text-muted leading-relaxed sm:text-lg">
        {BRANDING.longDescription}
      </p>
    </div>

    <!-- Module list -->
    <div class="mb-12 sm:mb-16">
      <h2 class="mb-6 text-sm font-medium uppercase tracking-wider text-mn-text-muted">
        Modules
      </h2>
      {sorted.length === 0 ? (
        <p class="text-mn-text-muted py-4">
          No modules available yet.
        </p>
      ) : (
        <div class="divide-y divide-midnight-border border-t border-b border-midnight-border">
          {sorted.map((module, index) => (
            <ModuleCard module={module} index={index} />
          ))}
        </div>
      )}
    </div>

    <!-- Credentials note -->
    <div class="mb-12 sm:mb-16">
      <p class="text-sm text-mn-text-muted">
        Self-paced. On-chain credentials via{" "}
        <a
          href={BRANDING.links.andamio}
          target="_blank"
          rel="noopener noreferrer"
          class="text-mn-primary transition-colors hover:text-mn-text underline underline-offset-2"
        >
          Andamio
        </a>.
      </p>
    </div>

    <!-- What is a Midnight credential? -->
    <section id="what-is-a-midnight-credential" class="mb-12 sm:mb-16 scroll-mt-24">
      <h2 class="mb-4 font-heading text-2xl font-semibold text-mn-text sm:text-3xl">
        What is a Midnight credential?
      </h2>
      <p class="max-w-2xl text-base text-mn-text-muted leading-relaxed sm:text-lg">
        A Midnight credential is an on-chain record that you completed a
        specific learning outcome in this course. It is minted via the
        Andamio protocol, tied to your wallet, and verifiable by anyone —
        no proprietary database, no platform lock-in. Because Andamio
        runs on Cardano, the same infrastructure used for Midnight
        badges also secures your other Cardano credentials, so a single
        wallet proves a portfolio of learning.
      </p>
    </section>

    <!-- How proof-of-learned works -->
    <section id="how-proof-of-learned-works" class="mb-12 sm:mb-16 scroll-mt-24">
      <h2 class="mb-4 font-heading text-2xl font-semibold text-mn-text sm:text-3xl">
        How proof-of-learned works
      </h2>
      <p class="max-w-2xl text-base text-mn-text-muted leading-relaxed sm:text-lg">
        Each module defines Student Learning Targets — concrete,
        observable outcomes a learner can demonstrate. You work through
        the lessons, complete the module assignment, and submit evidence
        on-chain. When the evidence meets the rubric, an Andamio-issued
        credential is minted to your wallet. Proof-of-learned means the
        artifact of your learning is the credential itself, not a grade
        locked inside a course platform.
      </p>
    </section>

    <!-- Three ways to take this course -->
    <div class="mb-12 sm:mb-16">
      <p style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 600; color: #ececec; margin-bottom: 1rem; line-height: 1.3;">
        Three ways to learn
      </p>
      <p style="font-size: 0.875rem; color: #a0a0a4; line-height: 1.7; max-width: 42rem; margin-bottom: 2.5rem;">
        This course runs on a new delivery model: one source of content, three interfaces. The same lessons, assignments, and credentials — whether you read them in a browser, learn them with an AI instructor, or fork them to teach your own version.
      </p>

      <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        <!-- Web -->
        <div>
          <p style="font-family: var(--font-heading); font-size: 1rem; font-weight: 500; color: #ececec; margin-bottom: 0.5rem;">
            On the web
          </p>
          <p style="font-size: 0.875rem; color: #a0a0a4; line-height: 1.7; max-width: 42rem; margin-bottom: 0.75rem;">
            Browse lessons in your browser. Submit assignments on-chain via wallet connection. No setup required.
          </p>
          <a
            href={sorted.length > 0 ? `/learn/${sorted[0].moduleCode}/1` : "#"}
            class="text-mn-primary transition-colors hover:text-mn-text"
            style="font-size: 0.875rem; text-decoration: underline; text-underline-offset: 2px;"
          >
            Start learning &rarr;
          </a>
        </div>

        <!-- Agent harness -->
        <div>
          <p style="font-family: var(--font-heading); font-size: 1rem; font-weight: 500; color: #ececec; margin-bottom: 0.5rem;">
            In Claude Code
          </p>
          <p style="font-size: 0.875rem; color: #a0a0a4; line-height: 1.7; max-width: 42rem; margin-bottom: 0.75rem;">
            Clone the repo, run <code class="text-mn-primary" style="font-family: var(--font-mono); font-size: 0.85em; background-color: #2a2a2a; border-radius: 2px; padding: 0.15em 0.4em;">/learn</code>. An AI instructor delivers lessons conversationally, guides exercises, and adapts to your pace. Progress tracked locally — no account needed.
          </p>
          <a
            href={BRANDING.links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-mn-primary transition-colors hover:text-mn-text"
            style="font-size: 0.875rem; text-decoration: underline; text-underline-offset: 2px;"
          >
            Clone and /learn &rarr;
          </a>
        </div>

        <!-- Fork as template -->
        <div>
          <p style="font-family: var(--font-heading); font-size: 1rem; font-weight: 500; color: #ececec; margin-bottom: 0.5rem;">
            Fork and teach
          </p>
          <p style="font-size: 0.875rem; color: #a0a0a4; line-height: 1.7; max-width: 42rem; margin-bottom: 0.75rem;">
            Fork the repo, swap in your own content, issue credentials on the same protocol. The repo is the course — you own the compiler.
          </p>
          <a
            href={BRANDING.links.githubFork}
            target="_blank"
            rel="noopener noreferrer"
            class="text-mn-primary transition-colors hover:text-mn-text"
            style="font-size: 0.875rem; text-decoration: underline; text-underline-offset: 2px;"
          >
            Fork this repo &rarr;
          </a>
        </div>
      </div>

      <p style="font-size: 0.875rem; color: #a0a0a4; margin-top: 2.5rem;">
        One source of truth. Three interfaces. Same SLTs, same assignments, same credentials.
      </p>
    </div>

    <!-- FAQ -->
    <section id="faq" class="mb-12 sm:mb-16 scroll-mt-24">
      <h2 class="mb-6 font-heading text-2xl font-semibold text-mn-text sm:text-3xl">
        Frequently asked questions
      </h2>
      <dl class="divide-y divide-midnight-border border-t border-b border-midnight-border">
        {FAQ_ENTRIES.map((entry) => (
          <div class="py-5">
            <dt class="mb-2 font-heading text-base font-semibold text-mn-text sm:text-lg">
              {entry.question}
            </dt>
            <dd class="max-w-2xl text-sm text-mn-text-muted leading-relaxed sm:text-base">
              {entry.answer}
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <!-- Community -->
    <div class="border-t border-midnight-border pt-10 sm:pt-12">
      <p class="mb-4 text-base text-mn-text-muted leading-relaxed">
        This course is a free community resource. It's made to be refined
        over time by the people who use it — if something is unclear, missing,
        or could be better, that's a contribution waiting to happen.
      </p>
      <a
        href={BRANDING.links.githubIssues}
        target="_blank"
        rel="noopener noreferrer"
      >
        <button
          class="inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mn-primary border border-midnight-border bg-transparent text-mn-text hover:bg-midnight-surface px-5 py-2.5 text-sm rounded-sm min-h-[44px]"
        >
          Give Feedback
        </button>
      </a>
    </div>

    <!-- Wordmark footer -->
    {BRANDING.logo.wordmark && (
      <div class="mt-16 flex justify-center sm:mt-20">
        <a href={BRANDING.links.midnight} target="_blank" rel="noopener noreferrer">
          <img
            src={BRANDING.logo.wordmark}
            alt=""
            class="h-6 opacity-20 transition-opacity hover:opacity-40"
          />
        </a>
      </div>
    )}
  </div>
</AppLayout>
